.result-page {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.icon {
  font-size: 60rpx;
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  display: block;
  margin-bottom: 60rpx;
}

.export-summary {
  width: 100%;
  background: #f5f5f5;
  padding: 30rpx;
  border-radius: 8rpx;
  margin-bottom: 60rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #888;
}

.value {
  color: #333;
}

.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}